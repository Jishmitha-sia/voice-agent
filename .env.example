# App
APP_ENV=development
APP_NAME=Voice Agent

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_LIVEKIT_URL=ws://127.0.0.1:7880

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
LIVEKIT_CLIENT_URL=ws://127.0.0.1:7880

# LiveKit
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-devsecret-devsecret-32chars

# Data stores
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=voice_agent
POSTGRES_USER=voice_agent
POSTGRES_PASSWORD=voice_agent
DATABASE_URL=postgresql://voice_agent:voice_agent@localhost:5432/voice_agent
REDIS_URL=redis://localhost:6380/0

# Auth
JWT_SECRET_KEY=change-this-before-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30

# Model providers
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen3:8b
STT_PROVIDER=faster-whisper
TTS_PROVIDER=piper
